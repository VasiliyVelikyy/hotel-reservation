<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-create-grade-sequence" author="Vmoskalev">
        <createSequence
                sequenceName="grade_seq"
                startValue="1"
                incrementBy="50"
                minValue="1"/>

        <comment>Sequence для генерации ID в таблице grade</comment>
    </changeSet>

    <changeSet id="002-1-create-grade-table" author="Vmoskalev">
        <createTable tableName="grade">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="mark" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="VARCHAR(500)"/>
            <column name="author" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <comment>Создание таблицы grade</comment>
    </changeSet>

    <changeSet id="002-2-add-grade-foreign-key" author="Vmoskalev">
        <addForeignKeyConstraint
                baseTableName="grade"
                baseColumnNames="hotel_id"
                referencedTableName="hotel"
                referencedColumnNames="id"
                constraintName="fk_grade_hotel_id"
                onDelete="CASCADE"
                onUpdate="NO ACTION"/>

        <comment>Foreign Key из grade в hotel</comment>
    </changeSet>

    <changeSet id="002-3-create-grade-index" author="Vmoskalev">
        <createIndex indexName="idx_grade_hotel_id" tableName="grade">
            <column name="hotel_id"/>
        </createIndex>

        <comment>Индекс для быстрого поиска оценок отеля</comment>
    </changeSet>

</databaseChangeLog>