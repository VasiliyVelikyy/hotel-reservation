<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-1-create-room-sequence" author="Vmoskalev">
        <createSequence
                sequenceName="room_seq"
                startValue="1"
                incrementBy="50"
                minValue="1"
        />

        <comment>Sequence для генерации ID в таблице room</comment>
    </changeSet>

    <changeSet id="002-2-create-room-table" author="Vmoskalev">
        <createTable tableName="room">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="number" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="max_count" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
            <column name="free_start_date" type="BIGINT"/>
            <column name="free_end_date" type="BIGINT"/>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="room"
                baseColumnNames="hotel_id"
                constraintName="fk_room_hotel"
                referencedTableName="hotel"
                referencedColumnNames="id"
                onDelete="CASCADE"
        />

        <comment>Создание таблицы room с внешним ключом на hotel</comment>
    </changeSet>

    <changeSet id="002-3-create-room-indexes" author="Vmoskalev">
        <createIndex indexName="idx_room_hotel_id" tableName="room">
            <column name="hotel_id"/>
        </createIndex>

        <createIndex indexName="idx_room_number" tableName="room">
            <column name="number"/>
        </createIndex>

        <createIndex indexName="idx_room_hotel_id_number" tableName="room">
            <column name="hotel_id"/>
            <column name="number"/>
        </createIndex>

        <comment>Индексы для таблицы room</comment>
    </changeSet>

</databaseChangeLog>