<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-1-create-users-sequence" author="Vmoskalev">
        <createSequence
                sequenceName="users_seq"
                startValue="1"
                incrementBy="50"
                minValue="1"
        />

        <comment>Sequence для генерации ID в таблице users</comment>
    </changeSet>

    <changeSet id="004-2-create-users-table" author="Vmoskalev">
        <createTable tableName="users">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_users_login"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_users_email"/>
            </column>
            <column name="hash_password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <comment>Создание таблицы users</comment>
    </changeSet>

    <changeSet id="004-3-create-users-indexes" author="Vmoskalev">
        <createIndex indexName="idx_users_role" tableName="users">
            <column name="role"/>
        </createIndex>

        <comment>Индексы для таблицы users</comment>
    </changeSet>
</databaseChangeLog>