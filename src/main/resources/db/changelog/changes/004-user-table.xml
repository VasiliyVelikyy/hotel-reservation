<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-1-create-user-sequence" author="Vmoskalev">
        <createSequence
                sequenceName="user_seq"
                startValue="1"
                incrementBy="50"
                minValue="1"
        />

        <comment>Sequence для генерации ID в таблице user</comment>
    </changeSet>

    <changeSet id="002-2-create-user-table" author="Vmoskalev">
        <createTable tableName="user">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_user_login"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_user_email"/>
            </column>
            <column name="hash_password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <comment>Создание таблицы user</comment>
    </changeSet>

    <changeSet id="002-3-create-user-indexes" author="Vmoskalev">
        <createIndex indexName="idx_user_role" tableName="user">
            <column name="role"/>
        </createIndex>

        <comment>Индексы для таблицы user</comment>
    </changeSet>
</databaseChangeLog>