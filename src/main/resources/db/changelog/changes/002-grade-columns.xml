<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-1-add-grade-columns" author="Vmoskalev">
        <addColumn tableName="hotel">
            <column name="current_rating" type="DOUBLE PRECISION" defaultValueNumeric="0.0"/>
            <column name="total_rating_sum" type="DOUBLE PRECISION" defaultValueNumeric="0.0"/>
            <column name="rating_count" type="INT" defaultValueNumeric="0"/>
        </addColumn>

        <comment>Добавление колонок для агрегации рейтинга (встраиваемый объект Grade)</comment>
    </changeSet>

</databaseChangeLog>